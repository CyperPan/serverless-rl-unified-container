# Copy to .env and adjust.
#
# 4060 Ti 8GB:  keep ENV_NAME=Hopper-v4 / batch_size as-is — fits comfortably.
# 4060 Ti 16GB: same defaults work + headroom.
# CPU-only host (Mac / no nvidia-docker): set NUM_GPUS_LEARNER=0
NUM_GPUS_LEARNER=1
UNIFIED_PREWARM=1
UNIFIED_WARMUP_LEARN=1
CUDA_VISIBLE_DEVICES=0

# Where to write per-run JSON
RESULT_DIR=./results
